meta {
  name: contacts
  type: graphql
  seq: 4
}

post {
  url: {{main_protocol}}://{{main_domain}}:{{main_port}}/graphql
  body: graphql
  auth: inherit
}

body:graphql {
  query me {
      me {
          contacts {
              id
              username
              alias
              transactionsCount
          }
      }
  }
}

body:graphql:vars {
  {}
}

settings {
  encodeUrl: true
}
