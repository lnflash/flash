meta {
  name: accountDefaultWallet
  type: graphql
  seq: 13
}

post {
  url: {{main_protocol}}://{{main_domain}}:{{main_port}}/graphql
  body: graphql
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:graphql {
  query accountDefaultWallet($username: Username!) {
      accountDefaultWallet(username: $username) {
          id
          walletCurrency
      }
  }
}

body:graphql:vars {
  {
      "username": "userB"
  }
  
}

settings {
  encodeUrl: true
}
