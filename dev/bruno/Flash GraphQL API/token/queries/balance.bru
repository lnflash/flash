meta {
  name: balance
  type: graphql
  seq: 2
}

post {
  url: {{main_protocol}}://{{main_domain}}:{{main_port}}/graphql
  body: graphql
  auth: inherit
}

body:graphql {
  query me {
      me {
          username
          defaultAccount {
              wallets {
                  ... on BTCWallet {
                      id
                      walletCurrency
                      balance
                      pendingIncomingBalance
                  }
                  ... on UsdWallet {
                      id
                      walletCurrency
                      balance
                      # pendingIncomingBalance
                  }
              }
          }
      }
  }
}

settings {
  encodeUrl: true
}
