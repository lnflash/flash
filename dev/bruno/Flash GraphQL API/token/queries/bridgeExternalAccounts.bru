meta {
  name: bridgeExternalAccounts
  type: graphql
  seq: 19
}

post {
  url: {{flashGraphqlUrl}}
  body: graphql
  auth: inherit
}

headers {
  Content-Type: application/json
}

body:graphql {
  query BridgeExternalAccounts {
    bridgeExternalAccounts {
      id
      bankName
      accountNumberLast4
      status
    }
  }
}

settings {
  encodeUrl: false
  timeout: 30000
}
