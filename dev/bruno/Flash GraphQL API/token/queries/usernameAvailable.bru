meta {
  name: usernameAvailable
  type: graphql
  seq: 14
}

post {
  url: {{flashGraphqlUrl}}
  body: graphql
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:graphql {
  query usernameAvailable($username: Username!) {
      usernameAvailable(username: $username)
  }
}

body:graphql:vars {
  {
      "username": "userB"
  }
  
}

settings {
  encodeUrl: true
}
