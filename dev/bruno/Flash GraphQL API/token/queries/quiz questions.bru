meta {
  name: quiz questions
  type: graphql
  seq: 5
}

post {
  url: {{main_protocol}}://{{main_domain}}:{{main_port}}/graphql
  body: graphql
  auth: inherit
}

body:graphql {
  query me {
      me {
          quizQuestions {
              question {
                  id
                  earnAmount
              }
              completed
          }
      }
  }
}

body:graphql:vars {
  {}
}

settings {
  encodeUrl: true
}
