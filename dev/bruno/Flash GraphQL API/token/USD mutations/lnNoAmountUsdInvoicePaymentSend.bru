meta {
  name: lnNoAmountUsdInvoicePaymentSend
  type: graphql
  seq: 5
}

post {
  url: {{main_protocol}}://{{main_domain}}:{{main_port}}/graphql
  body: graphql
  auth: inherit
}

body:graphql {
  mutation lnNoAmountUsdInvoicePaymentSend($input: LnNoAmountUsdInvoicePaymentInput!) {
    lnNoAmountUsdInvoicePaymentSend(input:$input) {
      status
      errors {
          message
      }
    }
  }
  
}

body:graphql:vars {
  {
      "input": {
          "walletId": "{{walletIdUsd}}",
          "paymentRequest": "",
          "amount": 600,
          "memo": "Test"
      }
  }
}

script:post-response {
  test("add invoice", function () {
      const jsonData = res.getBody();
      const invoice = jsonData.data.invoice.addInvoice
      expect(invoice.substring(0,2)).to.eql("ln")
  });
}

settings {
  encodeUrl: true
}
