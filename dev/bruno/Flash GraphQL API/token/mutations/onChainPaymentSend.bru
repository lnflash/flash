meta {
  name: onChainPaymentSend
  type: graphql
  seq: 3
}

post {
  url: {{main_protocol}}://{{main_domain}}:{{main_port}}/graphql
  body: graphql
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:graphql {
  mutation onChainPaymentSend($input: OnChainPaymentSendInput!) {
    onChainPaymentSend(input: $input) {
      errors {
        message
      }
      status
    }
  }
  
}

body:graphql:vars {
  {
    "input": {
        "walletId": "{{walletIdBtc}}",
          "address": "{{regtest-segwitV0-address}}",
          "amount": 5000,
          "memo": "",
          "targetConfirmations": 2
      }
  }
  
}

settings {
  encodeUrl: true
}
