meta {
  name: accountSetLnurlp
  type: graphql
  seq: 40
}

post {
  url: {{flashGraphqlUrl}}
  body: graphql
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:graphql {
  mutation accountSetLnurlp($input: AccountSetLnurlpInput!) {
    accountSetLnurlp(input: $input) {
      errors {
        message
      }
      account {
        id
        wallets {
          id
          walletCurrency
          lnurlp
        }
      }
    }
  }
}

body:graphql:vars {
  {
    "input": {
      "lnurl": "lnurl1dp68gurn8ghj7mrww35xjct5wfhyummn9e3k7mf0d46ku6twv94k2mt9de6hc6twv3khymn9wshxxmmd9akxatnwv468gurn8ghj7ampd3kx2ar0veekzar0wd5xjtnrdakj7tnhv4kxctttdehhwm30d3h82unvwqhhymn9wshxxcpndphxyer99uh8wet9v56nz0",
      "walletId": ""
    }
  }
}

settings {
  encodeUrl: true
}
