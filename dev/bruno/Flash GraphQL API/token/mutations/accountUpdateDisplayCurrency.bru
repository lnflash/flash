meta {
  name: accountUpdateDisplayCurrency
  type: graphql
  seq: 29
}

post {
  url: {{flashGraphqlUrl}}
  body: graphql
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:graphql {
  mutation accountUpdateDisplayCurrency($input: AccountUpdateDisplayCurrencyInput!) {
    accountUpdateDisplayCurrency(input:$input) {
      errors {
        message
      }
      account {
          defaultWalletId
          displayCurrency
      }
    }
  }
}

body:graphql:vars {
  {
      "input": {
          "currency": "CRC"
      }
  }
  
}

settings {
  encodeUrl: true
}
