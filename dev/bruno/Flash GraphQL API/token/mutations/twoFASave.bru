meta {
  name: twoFASave
  type: graphql
  seq: 31
}

post {
  url: {{main_protocol}}://{{main_domain}}:{{main_port}}/graphql
  body: graphql
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:graphql {
  mutation twoFASave($input: TwoFASaveInput!) {
    twoFASave(input: $input) {
      errors {
        message
      }
      success
    }
  }
}

body:graphql:vars {
  {
      "input": {
          "secret": "{{twoFASecret}}",
          "token": "123456"
      }
  }
}

settings {
  encodeUrl: true
}
