meta {
  name: intraledgerPaymentSend
  type: graphql
  seq: 18
}

post {
  url: {{flashGraphqlUrl}}
  body: graphql
  auth: inherit
}

body:graphql {
  mutation intraLedgerPaymentSend($input: IntraLedgerPaymentSendInput!) {
    intraLedgerPaymentSend(input:$input) {
      status
      errors {
        message
        path
      }
    }
  }
}

body:graphql:vars {
  {
      "input": {
          "walletId": "{{walletIdBtc}}",
          "amount": 100,
          "recipientWalletId": "{{walletIdUsd}}",
          "memo": "Test"
      }
  }
  
}

script:post-response {
  test("add invoice", function () {
      const jsonData = res.getBody();
      const invoice = jsonData.data.invoice.addInvoice
      expect(invoice.substring(0,2)).to.eql("ln")
  });
}

settings {
  encodeUrl: true
}
