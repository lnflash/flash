meta {
  name: accountGenerateLnurlp
  type: graphql
  seq: 41
}

post {
  url: {{flashGraphqlUrl}}
  body: graphql
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:graphql {
  mutation accountGenerateLnurlp($input: AccountGenerateLnurlpInput!) {
    accountGenerateLnurlp(input: $input) {
      errors {
        message
      }
      account {
        id
        wallets {
          id
          walletCurrency
          lnurlp
        }
      }
    }
  }
}

body:graphql:vars {
  {
    "input": {
      "walletId": ""
    }
  }
}

settings {
  encodeUrl: true
}
