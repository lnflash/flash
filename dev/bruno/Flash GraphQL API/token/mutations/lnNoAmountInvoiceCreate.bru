meta {
  name: lnNoAmountInvoiceCreate
  type: graphql
  seq: 21
}

post {
  url: {{main_protocol}}://{{main_domain}}:{{main_port}}/graphql
  body: graphql
  auth: inherit
}

body:graphql {
  mutation lnNoAmountInvoiceCreate($input: LnNoAmountInvoiceCreateInput!) {
    lnNoAmountInvoiceCreate(input: $input) {
      invoice {
        paymentRequest
        paymentHash
        paymentSecret
      }
      errors {
        message
      }
    }
  }
  
}

body:graphql:vars {
  {
      "input": {
          "walletId": "{{walletId}}",
          "memo": "Test"
      }
  }
}

script:post-response {
  test("add invoice", function () {
      const jsonData = res.getBody();
      const invoice = jsonData.data.invoice.addInvoice
      expect(invoice.substring(0,2)).to.eql("ln")
  });
}

settings {
  encodeUrl: true
}
