meta {
  name: setUsername
  type: graphql
  seq: 27
}

post {
  url: {{main_protocol}}://{{main_domain}}:{{main_port}}/graphql
  body: graphql
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:graphql {
  mutation setUsername($input: UserUpdateUsernameInput!) {
    userUpdateUsername(input:$input) {
      errors {
        message
      }
      user {
          username
      }
    }
  }
}

body:graphql:vars {
  {
      "input": {
          "username": "Bob"
      }
  }
  
}

settings {
  encodeUrl: true
}
