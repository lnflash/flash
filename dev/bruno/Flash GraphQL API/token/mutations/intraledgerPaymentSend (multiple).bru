meta {
  name: intraledgerPaymentSend (multiple)
  type: graphql
  seq: 19
}

post {
  url: {{main_protocol}}://{{main_domain}}:{{main_port}}/graphql
  body: graphql
  auth: inherit
}

body:graphql {
  mutation intraLedgerPaymentSend($input: IntraLedgerPaymentSendInput!) {
    a: intraLedgerPaymentSend(input:$input) {
      status
      errors {
        message
        path
      }
    }
  
