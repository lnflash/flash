meta {
  name: intraledgerUsdPaymentSend
  type: graphql
  seq: 20
}

post {
  url: {{main_protocol}}://{{main_domain}}:{{main_port}}/graphql
  body: graphql
  auth: inherit
}

body:graphql {
  mutation intraLedgerUsdPaymentSend($input: IntraLedgerUsdPaymentSendInput!) {
    intraLedgerUsdPaymentSend(input:$input) {
      status
      errors {
        message
        path
      }
    }
  }
}

body:graphql:vars {
  {
      "input": {
          "walletId": "{{walletIdUsd}}",
          "amount": 100,
          "recipientWalletId": "{{walletIdBtc}}",
          "memo": "Test"
      }
  }
  
}

script:post-response {
  test("add invoice", function () {
      const jsonData = res.getBody();
      const invoice = jsonData.data.invoice.addInvoice
      expect(invoice.substring(0,2)).to.eql("ln")
  });
}

settings {
  encodeUrl: true
}
