meta {
  name: bridgeInitiateWithdrawal
  type: graphql
  seq: 38
}

post {
  url: {{flashGraphqlUrl}}
  body: graphql
  auth: inherit
}

headers {
  Content-Type: application/json
}

body:graphql {
  mutation BridgeInitiateWithdrawal($input: BridgeInitiateWithdrawalInput!) {
    bridgeInitiateWithdrawal(input: $input) {
      errors {
        message
      }
      withdrawal {
        id
        amount
        currency
        status
        flashFeePercent
        flashFee
        flashFeeIsEstimate
        flashFeeNotice
        subtotalAmount
        finalAmount
        bridgeDeveloperFee
        bridgeExchangeFee
        bridgeTransferId
        createdAt
      }
    }
  }
}

body:graphql:vars {
  {
    "input": {
      "withdrawalId": "{{bridgeWithdrawalId}}"
    }
  }
}

settings {
  encodeUrl: false
  timeout: 30000
}
