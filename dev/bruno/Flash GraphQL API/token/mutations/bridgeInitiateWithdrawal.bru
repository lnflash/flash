meta {
  name: bridgeInitiateWithdrawal
  type: graphql
  seq: 39
}

post {
  url: {{flashGraphqlUrl}}
  body: graphql
  auth: inherit
}

headers {
  Content-Type: application/json
}

body:graphql {
  mutation BridgeInitiateWithdrawal($input: BridgeInitiateWithdrawalInput!) {
    bridgeInitiateWithdrawal(input: $input) {
      errors {
        message
        code
      }
      withdrawal {
        id
        amount
        currency
        status
        createdAt
      }
    }
  }
}

body:graphql:vars {
  {
    "input": {
      "amount": "10.00",
      "externalAccountId": "{{bridgeExternalAccountId}}"
    }
  }
}

settings {
  encodeUrl: false
  timeout: 30000
}
