meta {
  name: accountUpdateLnurlp
  type: graphql
  seq: 39
}

post {
  url: {{flashGraphqlUrl}}
  body: graphql
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:graphql {
  mutation accountUpdateLnurlp($input: AccountUpdateLnurlpInput!) {
    accountUpdateLnurlp(input: $input) {
      errors {
        message
      }
      account {
        id
        wallets {
          id
          walletCurrency
        }
      }
    }
  }
}

