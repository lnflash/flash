meta {
  name: RequestCashout
  type: graphql
  seq: 33
}

post {
  url: {{flashGraphqlUrl}}
  body: graphql
  auth: inherit
}

headers {
  Content-Type: application/json
  Authorization: ••••••
}

body:graphql {
  mutation Mutation($input: RequestCashoutInput!) {
    requestCashout(input: $input) {
      offer {
          offerId
          # exchangeRate
          expiresAt
          flashFee
          send
          receiveUsd
          receiveJmd
          walletId
      }
      errors {
        ... on GraphQLApplicationError {
          code
          message
          path
        }
      }
    }
  }
}

body:graphql:vars {
  {
    "input": {
      "walletId": "{{walletId}}",
      "amount": 1,
      "bankAccountId": "John Smith JMD - First Global"
    }
  }
}

script:post-response {
  const offerId = res.body?.data?.requestCashout?.offer?.offerId;
  if (offerId) {
    bru.setEnvVar("offerId", offerId);
  }
}

settings {
  encodeUrl: false
  timeout: 0
}
