meta {
  name: accountDisableNotificationChannel
  type: graphql
  seq: 37
}

post {
  url: {{flashGraphqlUrl}}
  body: graphql
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

body:graphql {
  mutation accountDisableNotificationChannel($input: AccountDisableNotificationChannelInput!) {
    accountDisableNotificationChannel(input: $input) {
      errors {
        message
      }
      account {
        notificationSettings {
          push {
            enabled
            disabledCategories
          }
        }
      }
    }
  }
}

body:graphql:vars {
  {
    "input": {
      "channel": "PUSH"
    }
  }
}

settings {
  encodeUrl: true
}
