meta {
  name: mapMarkers
  type: graphql
  seq: 3
}

post {
  url: {{main_protocol}}://{{main_domain}}:{{main_port}}/graphql
  body: graphql
  auth: inherit
}

body:graphql {
  query businessMapMarkers {
    businessMapMarkers {
      username
      mapInfo {
        title
        coordinates {
          latitude
          longitude
        }
      }
    }
  }
}

body:graphql:vars {
  {"range": "ONE_DAY"}
}

settings {
  encodeUrl: true
}
